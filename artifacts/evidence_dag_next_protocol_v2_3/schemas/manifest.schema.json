{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-dag-v2.3-manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaign_id", "experiment_id", "variant", "dataset_split",
    "candidate_configuration", "budgets", "gold_policy",
    "fair_comparison_verified", "schema_versions", "output_dir"
  ],
  "properties": {
    "campaign_id": {"type": "string", "minLength": 1},
    "experiment_id": {"type": "string", "minLength": 1},
    "variant": {"type": "string", "minLength": 1},
    "dataset_split": {"type": "string", "minLength": 1},
    "candidate_configuration": {"type": "object", "minProperties": 1},
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planner_calls_2hop", "planner_calls_3hop", "planner_calls_4hop", "total_llm_calls_4hop", "strong_calls"],
      "properties": {
        "planner_calls_2hop": {"type": "integer", "minimum": 0},
        "planner_calls_3hop": {"type": "integer", "minimum": 0},
        "planner_calls_4hop": {"type": "integer", "minimum": 0},
        "total_llm_calls_4hop": {"type": "integer", "minimum": 0},
        "strong_calls": {"type": "integer", "minimum": 0}
      }
    },
    "gold_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oracle_diagnostic", "gold_inputs_allowed_in_runtime"],
      "properties": {
        "oracle_diagnostic": {"type": "boolean"},
        "gold_inputs_allowed_in_runtime": {"type": "boolean"}
      }
    },
    "fair_comparison_verified": {"const": true},
    "schema_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "freeze_lock", "raw_record", "metrics"],
      "properties": {
        "manifest": {"const": "2.3.0"},
        "freeze_lock": {"const": "2.3.0"},
        "raw_record": {"const": "2.3.0"},
        "metrics": {"const": "2.3.0"}
      }
    },
    "output_dir": {"type": "string", "minLength": 1}
  }
}

